# ─── ROS2 빌드 아티팩트 ───────────────────────────────
build/
install/
log/
*.egg-info/

# ─── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.eggs/

# ─── 지도 파일 (용량 큼, 개인 산출물) ────────────────
map/
*.pgm
*.yaml

# ─── 시뮬레이션 로그 ─────────────────────────────────
*.bag
*.db3
rosbag2_*/

# ─── 스크린샷/결과 이미지 (results/에만 허용) ─────────
# results/ 폴더는 .gitkeep으로 빈 폴더 유지
*.png
!results/*.png

# ─── IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ─── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── 환경 변수 ────────────────────────────────────────
.env
*.env
